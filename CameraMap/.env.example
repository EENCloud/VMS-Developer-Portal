# Copy to .env.local and fill in your Eagle Eye Networks app credentials.
# Obtain these from https://developer.eagleeyenetworks.com/

VITE_EEN_CLIENT_ID=your_client_id
VITE_EEN_CLIENT_SECRET=your_client_secret

# Must be registered EXACTLY in your EEN app settings (string-exact match).
# 127.0.0.1 is NOT the same as localhost.
VITE_EEN_REDIRECT_URI=http://127.0.0.1:3333/callback

# Set to "true" to skip auth and render the bundled JSON fixtures (offline dev).
# You can also explore demo data at runtime via the "Explore demo data" button.
VITE_USE_FIXTURES=false
